---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = "オールド腕時計のキャリバー説明書ライブラリ - SEIKO等の日本製腕時計の取扱説明書を検索・閲覧" } = Astro.props;
const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title} | オールド腕時計のキャリバー説明書ライブラリ</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css">
  <style is:global>
    :root {
      --cream: #F5F5DC;
      --cream-dark: #E8E8D0;
      --gold: #D4AF37;
      --gold-light: #E5C555;
      --gold-dark: #B8960C;
      --silver: #C0C0C0;
      --watch-black: #1A1A1A;
    }
    
    * {
      box-sizing: border-box;
    }
    
    html {
      scroll-behavior: smooth;
    }
    
    body {
      font-family: 'Noto Sans JP', system-ui, sans-serif;
      background: linear-gradient(135deg, var(--cream) 0%, var(--cream-dark) 100%);
      min-height: 100vh;
      color: var(--watch-black);
    }
    
    /* Pagefind カスタマイズ */
    .pagefind-ui {
      --pagefind-ui-primary: var(--gold-dark);
      --pagefind-ui-text: var(--watch-black);
      --pagefind-ui-background: #ffffff;
      --pagefind-ui-border: #ddd;
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 8px;
      --pagefind-ui-font: 'Noto Sans JP', system-ui, sans-serif;
    }
    
    .pagefind-ui .pagefind-ui__search-input {
      font-size: 1.1rem;
      padding: 1rem 1.5rem;
      padding-left: calc(54px * var(--pagefind-ui-scale));
      padding-right: 1.5rem !important;
      border: 2px solid var(--gold);
      border-radius: 9999px;
    }

    .pagefind-ui .pagefind-ui__search-clear {
      display: none !important;
    }
    
    .pagefind-ui .pagefind-ui__search-input:focus {
      outline: none;
      border-color: var(--gold-dark);
      box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.2);
    }
  </style>
</head>
<body class="antialiased">
  <header class="sticky top-0 z-50 bg-cream/95 backdrop-blur-sm border-b-2 border-gold/30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2 text-watch-black hover:text-gold-dark transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="font-display font-bold text-lg hidden sm:block">オールド腕時計のキャリバー説明書ライブラリ</span>
          <span class="font-display font-bold text-lg sm:hidden">説明書ライブラリ</span>
        </a>
        <nav class="flex items-center gap-4">
          <a href="/caliber/" class="text-sm font-medium text-watch-black/70 hover:text-gold-dark transition-colors">
            一覧
          </a>
          <a href="/category/quartz/" class="text-sm font-medium text-watch-black/70 hover:text-gold-dark transition-colors">
            クォーツ
          </a>
          <a href="/category/mechanical/" class="text-sm font-medium text-watch-black/70 hover:text-gold-dark transition-colors">
            機械式
          </a>
        </nav>
      </div>
    </div>
  </header>

  <main class="min-h-[calc(100vh-4rem-12rem)]">
    <slot />
  </main>

  <footer class="bg-watch-black text-cream py-12 mt-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <h3 class="font-display font-bold text-gold mb-4">サイトについて</h3>
          <p class="text-cream/70 text-sm leading-relaxed">
            オールド腕時計のキャリバー説明書ライブラリは、SEIKO等の日本製腕時計の取扱説明書を収集・提供するサイトです。
          </p>
        </div>
        <div>
          <h3 class="font-display font-bold text-gold mb-4">カテゴリ</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/category/quartz/" class="text-cream/70 hover:text-gold transition-colors">クォーツ</a></li>
            <li><a href="/category/mechanical/" class="text-cream/70 hover:text-gold transition-colors">機械式</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-display font-bold text-gold mb-4">リンク</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/" class="text-cream/70 hover:text-gold transition-colors">トップページ</a></li>
            <li><a href="/caliber/" class="text-cream/70 hover:text-gold transition-colors">全キャリバー一覧</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-cream/20 mt-8 pt-8 text-center text-cream/50 text-sm">
        <p>&copy; {currentYear} オールド腕時計のキャリバー説明書ライブラリ</p>
      </div>
    </div>
  </footer>

  <script src="/pagefind/pagefind-ui.js" type="text/javascript"></script>
</body>
</html>
