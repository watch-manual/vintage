---
import Layout from '../layouts/Layout.astro';
---

<Layout title="トップページ" description="オールド腕時計のキャリバー説明書を検索・閲覧。SEIKO等の日本製腕時計の取扱説明書を収集。">
  <!-- Hero Section -->
  <section class="relative py-20 sm:py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-gold/10 via-cream to-cream-dark/50"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-gold/10 mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-gold-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-watch-black mb-6 leading-tight">
        オールド腕時計の<br>
        <span class="text-gold-dark">キャリバー説明書</span>ライブラリ
      </h1>
      <p class="text-lg sm:text-xl text-watch-black/70 mb-4 max-w-2xl mx-auto">
        SEIKO等の日本製腕時計の取扱説明書を検索・閲覧できます。
      </p>
      <!-- Search -->
      <div class="max-w-2xl mx-auto">
        <div id="search" class="pagefind-ui"></div>
      </div>
    </div>
  </section>

  <script>
    // Pagefind の初期化
    window.addEventListener('DOMContentLoaded', () => {
      if (window.PagefindUI) {
        const ui = new window.PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
          translations: {
            placeholder: 'キャリバー番号で検索（例：7123）',
            clear_search: 'クリア',
            load_more: 'もっと見る',
            search_label: '検索',
            filters_label: 'フィルター',
            zero_results: '「[SEARCH_TERM]」の検索結果はありません',
            many_results: '「[SEARCH_TERM]」の検索結果（[COUNT]件）',
            one_result: '「[SEARCH_TERM]」の検索結果（1件）',
            alt_search: '「[SEARCH_TERM]」の検索結果を表示しています',
            search_suggestion: '「[SEARCH_TERM]」の検索結果を表示しています',
          }
        });
        ui.triggerSearch('7123');
      }
    });
  </script>
</Layout>
